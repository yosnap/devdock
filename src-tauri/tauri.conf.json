{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevDock",
  "version": "0.1.0",
  "identifier": "com.paulo.devdock",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DevDock",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "scopes": [
        {
          "name": "open-ide",
          "cmd": "code",
          "args": true
        },
        {
          "name": "open-cursor",
          "cmd": "cursor",
          "args": true
        },
        {
          "name": "open-zed",
          "cmd": "zed",
          "args": true
        },
        {
          "name": "open-sublime",
          "cmd": "subl",
          "args": true
        },
        {
          "name": "open-idea",
          "cmd": "idea",
          "args": true
        },
        {
          "name": "open-webstorm",
          "cmd": "webstorm",
          "args": true
        },
        {
          "name": "open-vim",
          "cmd": "vim",
          "args": true
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
